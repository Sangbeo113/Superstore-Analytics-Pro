      <column caption='Size Waterfall' datatype='real' name='[Calculation_0175701047836673]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='- [Calculation_0931682451546113]' />
      </column>
      <column caption='is_top80' datatype='boolean' name='[Calculation_0175701051719683]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([profit])) / TOTAL(SUM([profit])) &lt;= 0.8'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Profit' datatype='real' name='[Calculation_0175701056720900]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / COUNTD([order_id])' />
      </column>
      <column caption='Revenue at Risk' datatype='real' default-format='C1033%' name='[Calculation_0175701066190854]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [discount] &gt; 0.3 THEN [sales] ELSE 0 END' />
      </column>
      <column caption='Avg Delay ' datatype='real' name='[Calculation_0220508412887040]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([ship_delay_days])' />
      </column>
      <column caption='Avg Ship Cost' datatype='real' name='[Calculation_0220508416499716]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([shipping_cost])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_0220508416987141]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([order_id])' />
      </column>
      <column caption='Total Sales' datatype='real' name='[Calculation_0931682450571264]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_0931682451546113]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])' />
      </column>
      <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_0931682451668994]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Loss Orders' datatype='integer' name='[Calculation_0931682452049923]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#10;    IF [profit] &lt; 0 THEN [order_id] END&#10;)' />
      </column>
      <column caption='Loss Rate %' datatype='real' default-format='p0.00%' name='[Calculation_0931682452209668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0931682452049923] / COUNTD([order_id])' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_0931682452467717]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Cost Ratio' datatype='real' name='[Calculation_0931682452553734]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([shipping_cost]) / SUM([sales])' />
      </column>
      <column caption='Is Loss Maker' datatype='string' name='[Calculation_0931682452615175]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [profit] &lt; 0 THEN &quot;Lỗ&quot;&#10;ELSE &quot;Lãi&quot;&#10;END' />
      </column>
      <column caption='Discount Band' datatype='string' name='[Calculation_0931682452750344]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discount] = 0 THEN &quot;0%&quot;&#10;ELSEIF [discount] &lt;= 0.1 THEN &quot;0-10%&quot;&#10;ELSEIF [discount] &lt;= 0.3 THEN &quot;10-30%&quot;&#10;ELSEIF [discount] &lt;= 0.5 THEN &quot;30-50%&quot;&#10;ELSE &quot;50%+&quot;&#10;END' />
      </column>
