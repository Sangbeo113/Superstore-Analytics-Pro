      <column caption='YoY Sales %' datatype='real' name='[Calculation_1231786855903234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([total_sales]) - LOOKUP(SUM([total_sales]), -1)) &#13;&#10;/ LOOKUP(SUM([total_sales]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='YoY Label' datatype='string' name='[Calculation_1231786857185284]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1231786855903234] &gt; 0 THEN&#13;&#10;&quot;▲ &quot; + STR(ROUND([Calculation_1231786855903234]*100,1)) + &quot;%&quot;&#13;&#10;ELSE&#13;&#10;&quot;▼ &quot; + STR(ROUND([Calculation_1231786855903234]*100,1)) + &quot;%&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
