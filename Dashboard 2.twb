    <worksheet name='Sheet 6'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#2c3e50' fontname='Segoe UI,Arial,sans-serif'>Bar – Revenue at Risk per Discount Band</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_sales+' name='federated.1xg56w21n6vwti12d07lv0lt24ha' />
          </datasources>
          <datasource-dependencies datasource='federated.1xg56w21n6vwti12d07lv0lt24ha'>
            <column caption='Revenue at Risk' datatype='real' default-format='C1033%' name='[Calculation_0175701066190854]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [discount] &gt; 0.3 THEN [sales] ELSE 0 END' />
            </column>
            <column caption='Discount Band' datatype='string' name='[Calculation_0931682452750344]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [discount] = 0 THEN &quot;0%&quot;&#10;ELSEIF [discount] &lt;= 0.1 THEN &quot;0-10%&quot;&#10;ELSEIF [discount] &lt;= 0.3 THEN &quot;10-30%&quot;&#10;ELSEIF [discount] &lt;= 0.5 THEN &quot;30-50%&quot;&#10;ELSE &quot;50%+&quot;&#10;END' />
            </column>
            <column caption='Category' datatype='string' name='[category]' role='dimension' type='nominal' />
            <column caption='Discount' datatype='real' name='[discount]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0931682452750344]' derivation='None' name='[none:Calculation_0931682452750344:nk]' pivot='key' type='nominal' />
            <column-instance column='[category]' derivation='None' name='[none:category:nk]' pivot='key' type='nominal' />
