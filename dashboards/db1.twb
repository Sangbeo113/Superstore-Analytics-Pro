              <calculation class='tableau' formula='AVG([profit])&#13;&#10;&#13;&#10;// Kéo vào Rows — phân theo [Discount Band]&#13;&#10;// Kết quả đúng từng band:&#13;&#10;// 0-10%: +62.56  |  10-30%: +21.00&#13;&#10;// 30-50%: -61.56  |  50%+: -98.89' />
