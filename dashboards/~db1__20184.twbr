    <worksheet name='Late Delivery Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='fact_sales' name='federated.1orvg5r154dbgb1gnmr3q1loeqow' />
          </datasources>
          <datasource-dependencies datasource='federated.1orvg5r154dbgb1gnmr3q1loeqow'>
            <column caption='Is Late Delivery' datatype='integer' name='[Calculation_0613587878166535]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [ship_mode] = &quot;Same Day&quot;       AND [ship_delay_days] &gt; 1 THEN 1&#13;&#10;ELSEIF [ship_mode] = &quot;First Class&quot; AND [ship_delay_days] &gt; 3 THEN 1&#13;&#10;ELSEIF [ship_mode] = &quot;Second Class&quot; AND [ship_delay_days] &gt; 4 THEN 1&#13;&#10;ELSEIF [ship_mode] = &quot;Standard Class&quot; AND [ship_delay_days] &gt; 6 THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='Overall Late Rate %' datatype='real' name='[Calculation_0632279592165378]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0613587878166535]) / COUNT([order_id]) * 100' />
