      <aliases enabled='yes' />
      <column caption='Loss_Order_Count' datatype='integer' name='[Calculation_0586924252835840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([profit] &lt; 0, 1, 0))' />
      </column>
      <column caption='S2_RevenueAtRisk' datatype='real' name='[Calculation_0586924252930049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([profit] &lt; 0, [sales], 0))' />
      </column>
      <column caption='Lỗ trung bình/đơn' datatype='real' name='[Calculation_0586924253052930]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0586924252930049] / [Calculation_0586924252835840]' />
      </column>
      <column caption='Loss Rate Label' datatype='string' name='[Calculation_0586924255670275]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND(SUM(IIF([profit]&lt;0,1,0)) / COUNT([order_id]) * 100, 1)) + &quot;% đơn lỗ&quot;' />
      </column>
      <column caption='Avg Loss per Order' datatype='real' name='[Calculation_0586924258611204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([profit]&lt;0, [profit], 0)) / SUM(IIF([profit]&lt;0, 1, 0))' />
      </column>
      <column caption='Avg Profit by Band' datatype='real' name='[Calculation_0586924260380679]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([profit])&#13;&#10;&#13;&#10;// Kéo vào Rows — phân theo [Discount Band]&#13;&#10;// Kết quả đúng từng band:&#13;&#10;// 0-10%: +62.56  |  10-30%: +21.00&#13;&#10;// 30-50%: -61.56  |  50%+: -98.89' />
      </column>
      <column caption='Loss Rate % by Band' datatype='real' name='[Calculation_0586924260925448]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([profit] &lt; 0, 1, 0)) / COUNT([order_id]) * 100' />
      </column>
      <column caption='Bar Color' datatype='string' name='[Calculation_0586924261556233]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([profit]) &gt;= 0 THEN &quot;Profit&quot;&#13;&#10;ELSE &quot;Loss&quot;&#13;&#10;END' />
      </column>
      <column caption='Avg Discount %' datatype='real' name='[Calculation_0586924310003725]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([discount]) * 100' />
      </column>
      <column caption='Avg Profit Margin %' datatype='real' name='[Calculation_0586924310073358]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales]) * 100' />
      </column>
      <column caption='Shipping Cost Ratio %' datatype='real' name='[Calculation_0613587878072326]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([shipping_cost]) / SUM([sales]) * 100' />
      </column>
      <column caption='Is Late Delivery' datatype='integer' name='[Calculation_0613587878166535]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ship_mode] = &quot;Same Day&quot;       AND [ship_delay_days] &gt; 1 THEN 1&#13;&#10;ELSEIF [ship_mode] = &quot;First Class&quot; AND [ship_delay_days] &gt; 3 THEN 1&#13;&#10;ELSEIF [ship_mode] = &quot;Second Class&quot; AND [ship_delay_days] &gt; 4 THEN 1&#13;&#10;ELSEIF [ship_mode] = &quot;Standard Class&quot; AND [ship_delay_days] &gt; 6 THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Overall Late Rate %' datatype='real' name='[Calculation_0632279592165378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0613587878166535]) / COUNT([order_id]) * 100' />
      </column>
      <column caption='Country Margin %' datatype='real' name='[Calculation_1311502979092482]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales]) * 100' />
      </column>
      <column caption='Capped Margin' datatype='real' name='[Calculation_1311502981005315]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Giới hạn min ở -20% để không làm lệch color scale&#13;&#10;IIF([Calculation_1311502979092482] &lt; -20, -20, [Calculation_1311502979092482])' />
      </column>
      <column caption='Total Sales' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_1348878091141120]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales])' />
      </column>
      <column caption='Total Profit' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_1348878091341825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit])' />
      </column>
      <column caption='Profit Margin %' datatype='real' default-format='p0.0%' name='[Calculation_1348878091419650]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Loss Orders' datatype='integer' name='[Calculation_1348878091517955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [profit] &lt; 0 THEN [order_id] END)' />
      </column>
      <column caption='Loss Rate %' datatype='real' default-format='p0.0%' name='[Calculation_1348878091571204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([profit] &lt; 0, 1, 0)) / COUNT([order_id]) * 100' />
      </column>
      <column caption='Avg Order Value' datatype='real' name='[Calculation_1348878091628549]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Shipping Cost Ratio' datatype='real' name='[Calculation_1348878091689990]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([shipping_cost]) / SUM([sales])' />
      </column>
      <column caption='Is Loss Maker' datatype='string' name='[Calculation_1348878091751431]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [profit] &lt; 0 THEN &quot;Lỗ&quot; ELSE &quot;Lãi&quot; END' />
      </column>
      <column caption='Discount Band' datatype='string' name='[Calculation_1348878091886600]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [discount]=0 THEN &quot;0%&quot; ELSEIF [discount]&lt;=0.1 THEN &quot;0-10%&quot; ELSEIF [discount]&lt;=0.3 THEN &quot;10-30%&quot; ELSEIF [discount]&lt;=0.5 THEN &quot;30-50%&quot; ELSE &quot;50%+&quot; END' />
      </column>
      <column caption='Is Loss' datatype='integer' name='[Calculation_1453611206733825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [profit] &lt; 0 THEN 1 ELSE 0 END' />
      </column>
      <column caption='Quarter_Label' datatype='string' name='[Calculation_1453611510333445]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR(YEAR([order_date])) + &quot; Q&quot; + STR(DATEPART(&quot;quarter&quot;, [order_date]))' />
      </column>
      <column caption='Quarter_Shade' datatype='string' name='[Calculation_1453611511386118]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&quot;quarter&quot;, [order_date]) = 4 THEN &quot;Q4 Peak&quot;&#13;&#10;ELSE &quot;Normal Quarters&quot;&#13;&#10;END' />
      </column>
