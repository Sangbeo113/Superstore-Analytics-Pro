      <aliases enabled='yes' />
      <column caption='Weighted Avg Cost' datatype='real' name='[Calculation_0632279589683201]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_shipping_cost]) / SUM([total_orders])' />
      </column>
      <column caption='Ship Mode Color' datatype='string' name='[Calculation_1311502969184256]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([avg_delay_days]) &lt;= 0.1 THEN &quot;Fast&quot;&#13;&#10;ELSEIF AVG([avg_delay_days]) &lt;= 2.5 THEN &quot;Good&quot;&#13;&#10;ELSEIF AVG([avg_delay_days]) &lt;= 3.5 THEN &quot;Warning&quot;&#13;&#10;ELSE &quot;Slow&quot;&#13;&#10;END' />
      </column>
