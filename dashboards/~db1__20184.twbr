      <column caption='Market Tier' datatype='string' name='[Calculation_0549541580873728]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1453611508727811] &gt;= 20 THEN &quot;Tier 1: &gt;20%&quot;&#13;&#10;ELSEIF [Calculation_1453611508727811] &gt;= 12 THEN &quot;Tier 2: 12-20%&quot;&#13;&#10;ELSEIF [Calculation_1453611508727811] &gt;= 8  THEN &quot;Tier 3: 8-12%&quot;&#13;&#10;ELSE &quot;Tier 4: &lt;8% (Alert)&quot;&#13;&#10;END' />
      </column>
      <column caption='label bar total' datatype='string' name='[Calculation_0549541584797697]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;$&quot; + STR(ROUND(SUM([total_sales])/1000000, 1)) + &quot;M&quot;' />
      </column>
      <column caption='Label margin ' datatype='string' name='[Calculation_0549541585424386]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(ROUND([Calculation_1453611508727811],1)) + &quot;%&quot;' />
      </column>
      <column caption='Margin % (Safe)' datatype='real' name='[Calculation_1453611481161730]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_profit]) / SUM([total_sales]) * 100' />
      </column>
      <column caption='Margin_Safe_Pct' datatype='real' name='[Calculation_1453611508727811]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([total_profit]) / SUM([total_sales]) * 100' />
      </column>
